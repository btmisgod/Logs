{
  // Draft protocol for:
  // 1. manager-only bootstrap workflow
  // 2. a minimal linear news task workflow
  //
  // Runtime reality:
  // - current community runtime consumes only the top-level `execution_spec`
  // - therefore bootstrap is the active execution spec
  // - the formal news workflow is defined in the same protocol as an activation template
  // - after bootstrap reaches `task_start`, the controller should patch the top-level
  //   `execution_spec` to the formal workflow execution_spec_template

  "protocol_meta": {
    "protocol_id": "bootstrap-news-simple-protocol-v0.5",
    "protocol_name": "Community bootstrap + simple international news workflow",
    "protocol_version": "0.5.0-draft",
    "status": "debug_draft",
    "goal": "Verify manager-only bootstrap, then run a simple linear news task workflow in the same group.",
    "source_of_truth": "group_protocol"
  },

  "group_identity": {
    "group_name": "Group Boot Workflow 33 Neko XHS",
    "group_slug": "group-boot-workflow-33-neko-xhs",
    "group_type": "bootstrap_test_group",
    "group_objective": "Run manager-only bootstrap and then a simple product-output workflow for international news aggregation.",
    "workflow_mode": "bootstrap_then_formal_workflow"
  },

  "members": {
    "manager_agent_id": "neko",
    "worker_agent_ids": ["33", "xhs"],
    "all_agent_ids": ["neko", "33", "xhs"],
    "role_assignments": {
      "manager": {
        "agent_id": "neko",
        "responsibility": "task planning, worker dispatch, acceptance, final delivery"
      },
      "material_collect": {
        "agent_id": "33",
        "responsibility": "collect candidate international hot topics and image candidates"
      },
      "draft_compile": {
        "agent_id": "xhs",
        "responsibility": "compile the final 10-item report based on approved material pool"
      }
    },
    "role_rules": {
      "only_manager_may_emit_formal_workflow_control_signals": true,
      "workers_may_submit_evidence_but_must_not_directly_advance_workflow": true,
      "server_advances_only_on_manager_formal_signals_after_step0": true,
      "manager_holds_decision_authority_for_step_transition": true,
      "step_scope_should_be_split_when_manager_cannot_finish_control_within_one_step": true
    }
  },

  "communication_rules": {
    "message_base_type": "content_plus_embedded_blocks",
    "primary_flow_types": ["start", "run", "result"],
    "embedded_blocks": {
      "content_block": "required",
      "status_block": "workflow_or_evidence_defined",
      "context_block": "system_defined"
    },
    "plain_text_is_allowed_for_collaboration_but_not_for_formal_transition": true,
    "formal_transition_requires_manager_status_block": true,
    "worker_structured_messages_are_evidence_only": true,
    "frontend_should_consume_server_projection_not_raw_transition_guessing": true
  },

  "status_block_rules": {
    "required_fields": [
      "workflow_id",
      "step_id",
      "lifecycle_phase",
      "author_agent_id",
      "author_role",
      "step_status",
      "related_message_id"
    ],
    "status_block_payload_location": "content.payload",
    "manager_control_signals_are_authoritative": true,
    "worker_evidence_statuses_are_non_authoritative": true,
    "missing_status_block_means_no_formal_progress_credit": true
  },

  "workflow": {
    "bootstrap_workflow": {
      "workflow_id": "bootstrap-manager-only-workflow-v2",
      "workflow_principle": "server_mechanical_progression_on_manager_only_control_signals",
      "server_led_preflight": {
        "step_id": "step0.handshake",
        "owner": "server",
        "goal": "Verify all required agents can sync, transport, and receive group protocol before bootstrap starts.",
        "required_checks": [
          "backend_health_ok",
          "session_sync_ok",
          "shared_ingress_ok",
          "required_worker_channel_ok",
          "protocol_visible_to_agents",
          "group_context_available"
        ],
        "formal_output": "handshake_report",
        "retry_kind": "recovery",
        "done_when": "all_required_agents_ready_for_bootstrap"
      },
      "bootstrap_task_brief": {
        "injected_by": "server",
        "injected_after": "step0.handshake",
        "goal": "Provide manager with the concrete task target before startup alignment begins.",
        "kind": "bootstrap_task_brief",
        "task_goal": "整理24小时内国际新闻热点，输出10条新闻热点汇总报告，每条新闻附100字简讯和配1张图",
        "time_scope": "last_24_hours",
        "topic_scope": "international_news",
        "target_count": 10,
        "per_item_brief_length": 100,
        "per_item_requires_image": true,
        "assigned_roles": {
          "manager": "neko",
          "material_collect": "33",
          "draft_compile": "xhs"
        },
        "delivery_definition": {
          "artifact_type": "final_report",
          "delivery_must_be_directly_renderable": true,
          "final_body_required_any_of": [
            "report_markdown",
            "render_blocks",
            "items"
          ],
          "per_item_image_rule": "each item must include image_url or image_attachment_ref",
          "image_hint_text_only_is_not_accepted": true,
          "must_include": [
            "10 hot topics",
            "100-word brief for each topic",
            "1 directly consumable image reference for each topic",
            "a directly renderable final report body"
          ]
        },
        "server_to_manager_prompt_contract": {
          "purpose": "Initialize manager with task target, role assignment, and the requirement to align worker capability during bootstrap.",
          "must_include": [
            "task_goal",
            "role_assignments",
            "current_bootstrap_stage",
            "required_formal_output_for_this_stage"
          ]
        }
      },
      "stage_order": [
        "step0.handshake",
        "step1.startup_plan",
        "step2.capability_close",
        "step3.ready_close",
        "task_start"
      ],
      "stages": {
        "step1.startup_plan": {
          "phase_kind": "alignment",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "manager",
          "output_consumer": "server_and_all_participants",
          "decision_authority": "manager",
          "goal": "Manager consumes bootstrap_task_brief, aligns target, and gives task-specific instructions to workers.",
          "worker_instruction_hint": {
            "33": "Explain how you will collect candidate international hot topics within the last 24 hours.",
            "xhs": "Explain how you will compile the final report after material approval."
          },
          "worker_evidence_expected": [
            "startup_alignment_submitted"
          ],
          "worker_evidence_payload_contract": {
            "kind": "startup_alignment_evidence",
            "required_fields": [
              "understanding_summary",
              "role_confirmed",
              "known_dependencies",
              "questions_or_risks"
            ]
          },
          "manager_formal_output": "startup_plan",
          "manager_formal_signal": "manager_step1_done",
          "manager_formal_payload_contract": {
            "kind": "startup_plan",
            "required_fields": [
              "startup_goal",
              "formal_workflow_summary",
              "role_assignments",
              "task_brief_ref",
              "completion_definition",
              "open_questions",
              "evidence_refs"
            ]
          },
          "start_condition": "step0.handshake completed and bootstrap_task_brief visible to manager",
          "completion_condition": "manager_step1_done visible",
          "redo_policy": "manager may keep collecting evidence within step instead of advancing",
          "recovery_policy": "transport_or_sync_failure_is_recovery_not_redo",
          "frontend_activation_required": true
        },
        "step2.capability_close": {
          "phase_kind": "capability_check",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "manager",
          "output_consumer": "server_and_all_participants",
          "decision_authority": "manager",
          "goal": "Manager verifies whether each worker can perform the concrete task assigned in bootstrap_task_brief.",
          "worker_instruction_hint": {
            "33": "Confirm whether you can collect 10 candidate hot topics with source, summary, and image candidate.",
            "xhs": "Confirm whether you can compile a 10-item report with 100-word briefs and image references."
          },
          "worker_evidence_expected": [
            "capability_scope_submitted",
            "capability_scope_adjusted"
          ],
          "worker_evidence_payload_contract": {
            "kind": "capability_scope_evidence",
            "required_fields": [
              "skills_checked",
              "permissions_checked",
              "scope_confirmed",
              "blocking_issues",
              "needs_adjustment"
            ]
          },
          "manager_formal_output": "capability_summary",
          "manager_formal_signal": "manager_step2_done",
          "manager_formal_payload_contract": {
            "kind": "capability_summary",
            "required_fields": [
              "participant_states",
              "capability_ok",
              "blocking_summary",
              "needs_adjustment",
              "evidence_refs"
            ]
          },
          "start_condition": "step1.startup_plan completed",
          "completion_condition": "manager_step2_done visible",
          "redo_policy": "business scope mismatch stays inside current step until manager closes it",
          "recovery_policy": "permission_or_channel_failure_is_recovery",
          "frontend_activation_required": true
        },
        "step3.ready_close": {
          "phase_kind": "readiness",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "manager",
          "output_consumer": "server_and_all_participants",
          "decision_authority": "manager",
          "goal": "Manager confirms bootstrap is complete and the simple news workflow may start.",
          "worker_instruction_hint": {
            "33": "State whether you are ready to begin material collection once task_plan starts.",
            "xhs": "State whether you are ready to compile the report once approved materials are available."
          },
          "worker_evidence_expected": [
            "task_ready_evidence"
          ],
          "worker_evidence_payload_contract": {
            "kind": "task_ready_receipt",
            "required_fields": [
              "ready",
              "dependency_check",
              "remaining_blockers",
              "expected_first_action"
            ]
          },
          "manager_formal_output": "readiness_summary",
          "manager_formal_signal": "manager_step3_done",
          "manager_formal_payload_contract": {
            "kind": "readiness_summary",
            "required_fields": [
              "ready_participants",
              "not_ready_participants",
              "remaining_blockers",
              "formal_start_preconditions_met",
              "evidence_refs"
            ]
          },
          "start_condition": "step2.capability_close completed",
          "completion_condition": "manager_step3_done visible",
          "redo_policy": "manager may continue collecting readiness evidence inside current step",
          "recovery_policy": "runtime_or_transport_breakage_is_recovery",
          "frontend_activation_required": true
        },
        "task_start": {
          "phase_kind": "formal_start",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "server",
          "output_consumer": "formal_workflow_runtime",
          "decision_authority": "manager",
          "goal": "Manager publishes formal task start and hands off to the simple news workflow.",
          "manager_formal_output": "startup_handoff_package",
          "manager_formal_signal": "task_start",
          "manager_formal_payload_contract": {
            "kind": "startup_handoff_package",
            "required_fields": [
              "group_context",
              "effective_workflow_id",
              "handoff_summary",
              "first_action",
              "artifact_refs"
            ]
          },
          "start_condition": "step3.ready_close completed",
          "completion_condition": "task_start visible",
          "frontend_activation_required": true
        }
      }
    },

    "formal_workflow": {
      "workflow_id": "international-news-simple-workflow-v1",
      "goal": "Collect hot international topics from the last 24 hours and deliver a 10-item final report with short briefs and image references.",
      "activation_rule": {
        "trigger": "bootstrap task_start visible",
        "activation_mode": "patch top-level execution_spec from execution_spec_template",
        "first_active_stage": "task_plan"
      },
      "task_brief": {
        "kind": "task_brief",
        "task_goal": "整理24小时内国际新闻热点，输出10条新闻热点汇总成报告，每条新闻附100字的简讯和配1张图",
        "time_scope": "last_24_hours",
        "topic_scope": "international_news",
        "target_count": 10,
        "per_item_brief_length": 100,
        "per_item_requires_image": true,
        "delivery_contract": {
          "must_be_directly_renderable": true,
          "final_body_required_any_of": [
            "report_markdown",
            "render_blocks",
            "items"
          ],
          "per_item_required_fields": [
            "headline",
            "brief_100_words",
            "source_ref",
            "image_url",
            "why_selected"
          ],
          "optional_item_fields": [
            "image_attachment_ref"
          ],
          "image_hint_text_only_is_not_accepted": true,
          "manager_must_reject_missing_renderable_body": true
        },
        "role_assignments": {
          "manager": "neko",
          "material_collect": "33",
          "draft_compile": "xhs"
        }
      },
      "stage_order": [
        "task_plan",
        "material_collect",
        "draft_compile",
        "final_deliver"
      ],
      "stages": {
        "task_plan": {
          "phase_kind": "planning",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "manager",
          "output_consumer": "all_participants",
          "decision_authority": "manager",
          "goal": "Manager breaks down the task and sends stage-specific instructions to 33 and xhs.",
          "manager_formal_output": "task_plan",
          "manager_formal_signal": "manager_task_plan_done",
          "manager_formal_payload_contract": {
            "kind": "task_plan",
            "required_fields": [
              "task_breakdown",
              "worker_assignments",
              "acceptance_rules",
              "handoff_rule",
              "blocking_risks",
              "evidence_refs"
            ]
          }
        },
        "material_collect": {
          "phase_kind": "content_collection",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "manager",
          "output_consumer": "draft_compile_worker_and_server",
          "decision_authority": "manager",
          "goal": "Worker 33 submits a candidate material pool; manager approves the material set for drafting.",
          "worker_agent_id": "33",
          "worker_evidence_expected": [
            "material_pool_submitted"
          ],
          "worker_evidence_payload_contract": {
            "kind": "candidate_material_pool",
            "required_fields": [
              "candidate_items"
            ],
            "candidate_item_required_fields": [
              "topic_title",
              "source",
              "published_at",
              "why_hot",
              "core_fact_summary",
              "image_candidate",
              "credibility_note"
            ]
          },
          "manager_formal_output": "approved_material_pool",
          "manager_formal_signal": "manager_materials_approved",
          "manager_formal_payload_contract": {
            "kind": "approved_material_pool",
            "required_fields": [
              "selected_materials",
              "rejected_materials",
              "rejection_reasons",
              "evidence_refs"
            ]
          }
        },
        "draft_compile": {
          "phase_kind": "content_drafting",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "manager",
          "output_consumer": "server_and_frontend_projection",
          "decision_authority": "manager",
          "goal": "Worker xhs compiles the 10-item report from the approved material pool; manager accepts the draft.",
          "worker_agent_id": "xhs",
          "worker_evidence_expected": [
            "draft_report_submitted"
          ],
          "worker_evidence_payload_contract": {
            "kind": "draft_report_v1",
            "required_fields": [
              "report_title",
              "report_markdown",
              "items"
            ],
            "item_required_fields": [
              "rank",
              "headline",
              "brief_100_words",
              "source_ref",
              "image_url",
              "why_selected"
            ],
            "optional_item_fields": [
              "image_attachment_ref"
            ],
            "delivery_requirements": [
              "draft body must be directly renderable",
              "every item must provide a directly consumable image reference",
              "image hint text alone is not accepted"
            ]
          },
          "manager_formal_output": "draft_acceptance",
          "manager_formal_signal": "manager_draft_accepted",
          "manager_formal_payload_contract": {
            "kind": "draft_acceptance",
            "required_fields": [
              "accepted",
              "issue_summary",
              "missing_items",
              "format_ok",
              "content_ok",
              "item_count_checked",
              "headline_check",
              "brief_length_check",
              "image_reference_check",
              "renderable_body_present",
              "evidence_refs"
            ]
          }
        },
        "final_deliver": {
          "phase_kind": "delivery",
          "owner": "manager",
          "dispatch_authority": "manager",
          "acceptance_authority": "manager",
          "output_consumer": "frontend_and_archive",
          "decision_authority": "manager",
          "goal": "Manager publishes the final report and closes the simple news workflow.",
          "manager_formal_output": "final_report",
          "manager_formal_signal": "manager_final_delivered",
          "manager_formal_payload_contract": {
            "kind": "final_report",
            "required_fields": [
              "final_report_ref",
              "report_title",
              "report_markdown",
              "items",
              "delivered_item_count",
              "delivery_complete",
              "final_summary",
              "item_count_checked",
              "headline_check",
              "brief_length_check",
              "image_reference_check",
              "renderable_body_present",
              "artifact_refs"
            ],
            "item_required_fields": [
              "rank",
              "headline",
              "brief_100_words",
              "source_ref",
              "image_url",
              "why_selected"
            ],
            "optional_item_fields": [
              "image_attachment_ref"
            ]
          }
        }
      },
      "execution_spec_template": {
        "execution_spec_id": "international-news-simple-execution-spec-v1",
        "workflow_id": "international-news-simple-workflow-v1",
        "initial_stage": "task_plan",
        "stage_order": ["task_plan", "material_collect", "draft_compile", "final_deliver"],
        "role_directory": {
          "manager_agent_ids": ["54f1cbf0-c8f4-4707-a85f-30e461c3e9e8"],
          "worker_agent_ids": [
            "b8beedf6-3540-4cf1-b22d-1dd6f5633b3a",
            "e1fb40b4-80b9-4baa-b740-cb5aa51fdee5"
          ]
        },
        "stages": {
          "task_plan": {
            "stage_id": "task_plan",
            "semantic_description": "Server advances only when manager formally closes task planning.",
            "allowed_roles": ["manager"],
            "accepted_status_blocks": [
              {
                "gate_id": "manager_start",
                "lifecycle_phase": "start",
                "step_statuses": ["manager_task_plan_started"],
                "allowed_roles": ["manager"]
              },
              {
                "gate_id": "manager_done",
                "lifecycle_phase": "result",
                "step_statuses": ["manager_task_plan_done"],
                "allowed_roles": ["manager"]
              }
            ],
            "completion_condition": {
              "all_of": [
                {
                  "gate_id": "manager_done",
                  "min_count": 1,
                  "required_agent_ids": ["54f1cbf0-c8f4-4707-a85f-30e461c3e9e8"]
                }
              ]
            },
            "next_stage": "material_collect"
          },
          "material_collect": {
            "stage_id": "material_collect",
            "semantic_description": "Worker 33 submits material pool evidence; server advances only when manager approves materials.",
            "allowed_roles": ["manager"],
            "accepted_status_blocks": [
              {
                "gate_id": "manager_start",
                "lifecycle_phase": "start",
                "step_statuses": ["manager_material_collect_started"],
                "allowed_roles": ["manager"]
              },
              {
                "gate_id": "manager_done",
                "lifecycle_phase": "result",
                "step_statuses": ["manager_materials_approved"],
                "allowed_roles": ["manager"]
              }
            ],
            "completion_condition": {
              "all_of": [
                {
                  "gate_id": "manager_done",
                  "min_count": 1,
                  "required_agent_ids": ["54f1cbf0-c8f4-4707-a85f-30e461c3e9e8"]
                }
              ]
            },
            "next_stage": "draft_compile"
          },
          "draft_compile": {
            "stage_id": "draft_compile",
            "semantic_description": "Worker xhs submits report draft evidence; server advances only when manager accepts the draft.",
            "allowed_roles": ["manager"],
            "accepted_status_blocks": [
              {
                "gate_id": "manager_start",
                "lifecycle_phase": "start",
                "step_statuses": ["manager_draft_compile_started"],
                "allowed_roles": ["manager"]
              },
              {
                "gate_id": "manager_done",
                "lifecycle_phase": "result",
                "step_statuses": ["manager_draft_accepted"],
                "allowed_roles": ["manager"]
              }
            ],
            "completion_condition": {
              "all_of": [
                {
                  "gate_id": "manager_done",
                  "min_count": 1,
                  "required_agent_ids": ["54f1cbf0-c8f4-4707-a85f-30e461c3e9e8"]
                }
              ]
            },
            "next_stage": "final_deliver"
          },
          "final_deliver": {
            "stage_id": "final_deliver",
            "semantic_description": "Manager delivers the final report and closes the workflow.",
            "allowed_roles": ["manager"],
            "accepted_status_blocks": [
              {
                "gate_id": "manager_done",
                "lifecycle_phase": "result",
                "step_statuses": ["manager_final_delivered"],
                "allowed_roles": ["manager"]
              }
            ],
            "completion_condition": {
              "all_of": [
                {
                  "gate_id": "manager_done",
                  "min_count": 1,
                  "required_agent_ids": ["54f1cbf0-c8f4-4707-a85f-30e461c3e9e8"]
                }
              ]
            },
            "next_stage": null
          }
        }
      }
    }
  },

  "execution_spec": {
    "execution_spec_id": "bootstrap-manager-only-execution-spec-v2",
    "workflow_id": "bootstrap-manager-only-workflow-v2",
    "initial_stage": "step1",
    "stage_order": ["step1", "step2", "step3", "task_start"],
    "role_directory": {
      "manager_agent_ids": ["54f1cbf0-c8f4-4707-a85f-30e461c3e9e8"],
      "worker_agent_ids": [
        "b8beedf6-3540-4cf1-b22d-1dd6f5633b3a",
        "e1fb40b4-80b9-4baa-b740-cb5aa51fdee5"
      ]
    },
    "stages": {
      "step1": {
        "stage_id": "step1",
        "semantic_description": "Server advances only when manager formally closes startup plan stage.",
        "allowed_roles": ["manager"],
        "accepted_status_blocks": [
          {
            "gate_id": "manager_start",
            "lifecycle_phase": "start",
            "step_statuses": ["manager_step1_started"],
            "allowed_roles": ["manager"]
          },
          {
            "gate_id": "manager_done",
            "lifecycle_phase": "result",
            "step_statuses": ["manager_step1_done"],
            "allowed_roles": ["manager"]
          }
        ],
        "completion_condition": {
          "all_of": [
            {
              "gate_id": "manager_done",
              "min_count": 1,
              "required_agent_ids": ["54f1cbf0-c8f4-4707-a85f-30e461c3e9e8"]
            }
          ]
        },
        "next_stage": "step2"
      },
      "step2": {
        "stage_id": "step2",
        "semantic_description": "Server advances only when manager formally closes capability check stage.",
        "allowed_roles": ["manager"],
        "accepted_status_blocks": [
          {
            "gate_id": "manager_start",
            "lifecycle_phase": "start",
            "step_statuses": ["manager_step2_started"],
            "allowed_roles": ["manager"]
          },
          {
            "gate_id": "manager_done",
            "lifecycle_phase": "result",
            "step_statuses": ["manager_step2_done"],
            "allowed_roles": ["manager"]
          }
        ],
        "completion_condition": {
          "all_of": [
            {
              "gate_id": "manager_done",
              "min_count": 1,
